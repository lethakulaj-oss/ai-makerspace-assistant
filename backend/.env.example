# Database Configuration
DATABASE_URL=postgresql://user:password@your-neon-host/makerspace_db

# Groq API (replaces Ollama — get free key at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ChromaDB Configuration
CHROMA_PERSIST_DIR=./chroma_data

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=False

# CORS Origins — add your Vercel frontend URL here
CORS_ORIGINS=["https://your-app.vercel.app","http://localhost:5173"]
